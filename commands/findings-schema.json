{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "codegate/findings-schema.json",
  "title": "FindingsFile",
  "description": "Contract for findings.json written by the review agent (Phase 1) and consumed by post_findings.py (Phase 2).",
  "type": "object",
  "required": ["schema_version", "pr_id", "repo", "vcs", "review_modes", "findings"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0",
      "description": "Schema version"
    },
    "pr_id": {
      "type": "integer",
      "description": "Pull request / PR number"
    },
    "repo": {
      "type": "string",
      "description": "Repository name or ID"
    },
    "vcs": {
      "type": "string",
      "enum": ["ado", "github"],
      "description": "VCS provider"
    },
    "review_modes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Active review modes, e.g. [\"standard\", \"security\"]"
    },
    "findings": {
      "type": "array",
      "description": "List of code review findings",
      "items": {
        "$ref": "#/$defs/Finding"
      }
    },
    "fix_verifications": {
      "type": "array",
      "description": "Fix verification results from a re-push (optional)",
      "items": {
        "$ref": "#/$defs/FixVerification"
      }
    },
    "suppressed_findings": {
      "type": "array",
      "description": "Findings suppressed by intent markers or dismissal patterns (optional)",
      "items": {
        "$ref": "#/$defs/SuppressedFinding"
      }
    },
    "tool_calls": {
      "type": "integer",
      "minimum": 0,
      "description": "Total tool calls used by the agent (for monitoring cap)"
    },
    "agent": {
      "type": ["string", "null"],
      "enum": ["codex", "claude", "gemini", null],
      "description": "Agent that produced this file"
    },
    "token_usage": {
      "type": "object",
      "properties": {
        "input_tokens": {"type": "integer", "minimum": 0},
        "output_tokens": {"type": "integer", "minimum": 0}
      },
      "required": ["input_tokens", "output_tokens"],
      "additionalProperties": false
    }
  },
  "$defs": {
    "Finding": {
      "type": "object",
      "required": ["id", "file", "line", "severity", "category", "title", "message", "confidence"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": ["string", "null"],
          "description": "Stable 8-char hex hash assigned by post_findings.py. Set to null — the poster computes it."
        },
        "file": {
          "type": "string",
          "description": "File path relative to repo root"
        },
        "line": {
          "type": "integer",
          "minimum": 1,
          "description": "Line number of the finding"
        },
        "severity": {
          "type": "string",
          "enum": ["critical", "warning", "suggestion"],
          "description": "Finding severity level"
        },
        "category": {
          "type": "string",
          "enum": ["security", "performance", "best_practices", "code_style", "documentation"],
          "description": "Finding category"
        },
        "title": {
          "type": "string",
          "description": "Short one-line summary of the finding"
        },
        "message": {
          "type": "string",
          "description": "Full description of the finding"
        },
        "confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Confidence score (0.0 – 1.0). Findings below 0.7 are filtered out."
        },
        "suggestion": {
          "type": ["string", "null"],
          "description": "Optional suggested fix"
        }
      }
    },
    "SuppressedFinding": {
      "type": "object",
      "required": ["id", "file", "line", "category", "title", "reason"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Finding ID (e.g. cr-001) or generated identifier"
        },
        "file": {
          "type": "string",
          "description": "File path relative to repo root"
        },
        "line": {
          "type": "integer",
          "minimum": 1,
          "description": "Line number of the suppressed finding"
        },
        "category": {
          "type": "string",
          "enum": ["security", "performance", "best_practices", "code_style", "documentation"],
          "description": "Finding category"
        },
        "title": {
          "type": "string",
          "description": "Short summary of the suppressed finding"
        },
        "reason": {
          "type": "string",
          "description": "Why this finding was suppressed"
        },
        "dismissed_id": {
          "type": ["string", "null"],
          "description": "Use 'intent-marker' for intent markers, 'never-flag' for never_flag rules, or a cr-id"
        },
        "severity": {
          "type": ["string", "null"],
          "enum": ["critical", "warning", "suggestion", null],
          "description": "Optional severity level of the suppressed finding"
        }
      }
    },
    "RuleChecked": {
      "type": "object",
      "required": ["id", "applied_to", "findings_generated"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Rule identifier, e.g. PRJ-001"
        },
        "applied_to": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of files the rule was checked against"
        },
        "findings_generated": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of findings produced by this rule"
        }
      }
    },
    "FixVerification": {
      "type": "object",
      "required": ["cr_id", "status", "reason"],
      "additionalProperties": false,
      "properties": {
        "cr_id": {
          "type": "string",
          "pattern": "^[0-9a-f]{8}$",
          "description": "Matches a Finding.id hash from the prior review (8-char hex)"
        },
        "status": {
          "type": "string",
          "enum": ["fixed", "still_present", "not_relevant", "justified", "deferred"],
          "description": "Outcome of fix verification"
        },
        "reason": {
          "type": "string",
          "description": "Human-readable explanation of the classification"
        },
        "counter_reason": {
          "type": ["string", "null"],
          "description": "Counter-argument posted as reply when status is still_present"
        },
        "developer_reply": {
          "type": ["string", "null"],
          "description": "Developer reply text that informed the classification"
        }
      }
    }
  }
}
